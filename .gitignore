# =============================================================================
# Staffora Platform .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/

# -----------------------------------------------------------------------------
# Bun
# -----------------------------------------------------------------------------
bun.lockb
*.bunx

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Keep the example
!.env.example
!docker/.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Runtime data
# -----------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Coverage & Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.coverage/
htmlcov/

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Docker volume data (if stored locally)
docker/data/
docker/volumes/

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.cache

# -----------------------------------------------------------------------------
# Secrets & Credentials
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
secrets.json
service-account.json

# -----------------------------------------------------------------------------
# Uploads & User Data
# -----------------------------------------------------------------------------
uploads/
storage/
public/uploads/

# -----------------------------------------------------------------------------
# Generated files
# -----------------------------------------------------------------------------
*.generated.*
generated/

# -----------------------------------------------------------------------------
# Package manager locks (keep bun.lockb comment above)
# -----------------------------------------------------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
.vercel
.netlify
