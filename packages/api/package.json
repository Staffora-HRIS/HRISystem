{
  "name": "@staffora/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "dev": "bun run --watch src/app.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "build": "bun build src/app.ts --outdir dist --target bun",
    "start": "bun run dist/app.js",
    "start:worker": "bun run src/worker.ts",
    "test": "bun test src/test",
    "test:watch": "bun test src/test --watch",
    "test:coverage": "bun test src/test --coverage",
    "lint": "eslint --config ../../eslint.config.js src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate:up": "bun run src/db/migrate.ts up",
    "migrate:down": "bun run src/db/migrate.ts down",
    "migrate:create": "bun run src/db/migrate.ts create",
    "db:seed": "bun run src/db/seed.ts",
    "bootstrap:root": "bun run src/scripts/bootstrap-root.cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@better-auth/infra": "^0.1.8",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/swagger": "^1.1.6",
    "@sinclair/typebox": "^0.34.11",
    "@types/pg": "^8.16.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.4",
    "elysia": "^1.1.26",
    "exceljs": "^4.4.0",
    "firebase-admin": "^13.0.2",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.16",
    "otpauth": "^9.3.5",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.1.14",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@staffora/shared": "workspace:*"
  }
}
