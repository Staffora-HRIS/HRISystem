{
  "name": "staffora-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @staffora/api dev",
    "dev:web": "bun run --filter @staffora/web dev",
    "dev:worker": "bun run --filter @staffora/api dev:worker",
    "build": "bun run --filter '*' build",
    "build:api": "bun run --filter @staffora/api build",
    "build:web": "bun run --filter @staffora/web build",
    "test": "bun run --filter '*' test",
    "test:api": "bun run --filter @staffora/api test",
    "test:web": "bun run --filter @staffora/web test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "migrate": "bun run migrate:up",
    "migrate:up": "bun run --filter @staffora/api migrate:up",
    "migrate:down": "bun run --filter @staffora/api migrate:down",
    "migrate:create": "bun run --filter @staffora/api migrate:create",
    "db:seed": "bun run --filter @staffora/api db:seed",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:ps": "docker compose -f docker/docker-compose.yml ps",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/.turbo packages/*/dist"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.10",
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "brace-expansion": "^2.0.3",
    "defu": "^6.1.7",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "esbuild": "^0.25.12",
    "fast-xml-parser": "^5.7.0",
    "file-type": "^22.0.1",
    "hono": "^4.12.15",
    "@hono/node-server": "^1.19.13",
    "kysely": "^0.28.16",
    "lodash": "^4.18.1",
    "minimatch": "^9.0.7",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^0.1.13",
    "postcss": "^8.5.10",
    "protobufjs": "^7.5.5",
    "qs": "^6.15.1",
    "rollup": "^4.60.2",
    "uuid": "^14.0.0",
    "vite": "^6.4.2"
  }
}
