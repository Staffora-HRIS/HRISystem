# =============================================================================
# Staffora Platform Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================
# Legend: [REQUIRED] = must set before running, [OPTIONAL] = has sensible defaults

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL Configuration [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_USER=hris
# Change to a secure password in production
POSTGRES_PASSWORD=hris_dev_password
POSTGRES_DB=hris
POSTGRES_PORT=5432

# Full database URL (constructed from above, used by application)
DATABASE_URL=postgres://hris:hris_dev_password@localhost:5432/hris

# Application-role connection URL (non-superuser with NOBYPASSRLS)
# Used by Better Auth and runtime queries
# DATABASE_APP_URL=postgres://hris_app:hris_app_dev_password@localhost:5432/hris

# Individual DB overrides (optional, DATABASE_URL takes precedence)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=hris
# DB_PASSWORD=hris_dev_password
# DB_NAME=hris
# DB_SSL=false
# DB_DEBUG=false
# DB_CONNECT_TIMEOUT=30000
# DB_IDLE_TIMEOUT=60000
# DB_MAX_CONNECTIONS=20

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_HOST=localhost
# REDIS_DB=0
# REDIS_KEY_PREFIX=staffora:
# REDIS_MAX_RETRIES=3
# REDIS_CONNECT_TIMEOUT=5000
# REDIS_COMMAND_TIMEOUT=5000
# REDIS_RETRY_DELAY=100

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=3000
# API_URL=http://localhost:3000
# APP_URL=http://localhost:5173
# MAX_BODY_SIZE=1mb
# TRUSTED_PROXIES=

# -----------------------------------------------------------------------------
# Web Configuration
# -----------------------------------------------------------------------------
WEB_PORT=5173

# -----------------------------------------------------------------------------
# Authentication (BetterAuth) [REQUIRED]
# -----------------------------------------------------------------------------
# Session secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-use-openssl-rand-base64-32

# CSRF protection secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
CSRF_SECRET=change-me-use-openssl-rand-base64-32

# BetterAuth secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32

# BetterAuth API key (for Better Auth Infra dashboard)
# Get this from https://dash.better-auth.com after connecting your project
BETTER_AUTH_API_KEY=

# BetterAuth URL (your API URL - used for auth callbacks)
BETTER_AUTH_URL=http://localhost:3000

# API URL for frontend (used by Better Auth client)
VITE_API_URL=http://localhost:3000

# Enforce MFA for admin users
# ENFORCE_ADMIN_MFA=false

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Maximum requests per minute per IP
RATE_LIMIT_MAX=100
# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=60000

# -----------------------------------------------------------------------------
# File Storage [OPTIONAL]
# -----------------------------------------------------------------------------
# STORAGE_TYPE=local
# STORAGE_PATH=./uploads
# STORAGE_BASE_URL=http://localhost:3000/uploads
# S3_BUCKET=
# S3_REGION=eu-west-2
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_EXPORT_BUCKET=
# S3_EXPORT_PREFIX=exports/

# AWS alternative credentials (used if S3_ACCESS_KEY not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Email (SMTP) [OPTIONAL]
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@staffora.co.uk

# -----------------------------------------------------------------------------
# Push Notifications (Firebase) [OPTIONAL]
# -----------------------------------------------------------------------------
# FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# Observability — Sentry [OPTIONAL]
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry [OPTIONAL]
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=staffora-api
# OTEL_SERVICE_VERSION=
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
# OTEL_LOG_LEVEL=info
# OTEL_METRICS_EXPORTER=otlp

# -----------------------------------------------------------------------------
# Background Workers [OPTIONAL]
# -----------------------------------------------------------------------------
# WORKER_TYPE=all
# WORKER_HEALTH_PORT=3001
# OUTBOX_BATCH_SIZE=100
# OUTBOX_POLL_INTERVAL=5000
# ENABLE_OUTBOX_POLLING=true

# Export worker
# EXPORT_BASE_URL=http://localhost:3000
# EXPORT_STORAGE_PATH=./exports

# PDF worker
# PDF_BASE_URL=http://localhost:3000
# PDF_STORAGE_PATH=./pdfs

# Worker concurrency and scheduling
# WORKER_CONCURRENCY=5
# WORKER_MAX_RETRIES=3
# WORKER_RETRY_DELAY=5000

# -----------------------------------------------------------------------------
# Database Migrations [OPTIONAL]
# -----------------------------------------------------------------------------
# MIGRATIONS_DIR=./migrations

# -----------------------------------------------------------------------------
# Bootstrap (first-time setup) [OPTIONAL]
# -----------------------------------------------------------------------------
# ROOT_TENANT_NAME=Staffora
# ROOT_TENANT_SLUG=staffora
# ROOT_USER_EMAIL=admin@staffora.co.uk
# ROOT_USER_PASSWORD=
# ROOT_USER_NAME=Admin

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable MFA requirement for all users
FEATURE_MFA_REQUIRED=false
# Enable audit logging
FEATURE_AUDIT_ENABLED=true
# Enable API rate limiting
FEATURE_RATE_LIMIT_ENABLED=true
