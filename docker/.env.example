# =============================================================================
# Staffora Platform Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================
# Legend: [REQUIRED] = must set before running, [OPTIONAL] = has sensible defaults

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL Configuration [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_USER=hris
# Change to a secure password in production
POSTGRES_PASSWORD=hris_dev_password
POSTGRES_DB=hris
POSTGRES_PORT=5432

# Full database URL (constructed from above, used by application)
DATABASE_URL=postgres://hris:hris_dev_password@localhost:5432/hris

# Application-role connection URL (non-superuser with NOBYPASSRLS)
# Used by Better Auth and runtime queries
# DATABASE_APP_URL=postgres://hris_app:hris_dev_password@localhost:5432/hris

# Application-role (hris_app) credentials — used for DATABASE_APP_URL
# POSTGRES_APP_USER=hris_app
# POSTGRES_APP_PASSWORD=hris_dev_password

# Individual DB overrides (optional, DATABASE_URL takes precedence)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=hris
# DB_PASSWORD=hris_dev_password
# DB_NAME=hris
# DB_SSL=false
# DB_DEBUG=false
# DB_CONNECT_TIMEOUT=30000
# DB_IDLE_TIMEOUT=60000
# DB_MAX_CONNECTIONS=20

# -----------------------------------------------------------------------------
# PgBouncer Connection Pooler [OPTIONAL]
# -----------------------------------------------------------------------------
# PgBouncer sits between the application and PostgreSQL to multiplex
# connections.  In Docker, DATABASE_APP_URL is routed through PgBouncer
# automatically.  For local development without Docker, set
# PGBOUNCER_ENABLED=true if you have a local PgBouncer instance.
#
# Host port for PgBouncer admin/stats access. Default: 6432
PGBOUNCER_PORT=6432
# Force PgBouncer mode even when port is not 6432 (disables prepared stmts)
# PGBOUNCER_ENABLED=false

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_HOST=localhost
# REDIS_DB=0
# REDIS_KEY_PREFIX=staffora:
# REDIS_MAX_RETRIES=3
# REDIS_CONNECT_TIMEOUT=5000
# REDIS_COMMAND_TIMEOUT=5000
# REDIS_RETRY_DELAY=100

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=3000
# API_URL=http://localhost:3000
# APP_URL=http://localhost:5173
# MAX_BODY_SIZE=1mb
# TRUSTED_PROXIES=

# Number of API replicas for horizontal scaling (used by docker-compose.scale.yml)
# API_REPLICAS=3

# Admin IP Allowlist — comma-separated IPs or CIDRs allowed to access admin endpoints.
# When empty or unset, all IPs are allowed. Supports IPv4 addresses and CIDR notation.
# Examples: "10.0.0.1", "192.168.1.0/24", "10.0.0.1,172.16.0.0/12,192.168.1.100"
# ADMIN_IP_ALLOWLIST=

# -----------------------------------------------------------------------------
# Web Configuration
# -----------------------------------------------------------------------------
WEB_PORT=5173

# -----------------------------------------------------------------------------
# Authentication (BetterAuth) [REQUIRED]
# -----------------------------------------------------------------------------
# Session secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE-ME-session-run-openssl-rand-base64-32

# CSRF protection secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
CSRF_SECRET=CHANGE-ME-csrf-run-openssl-rand-base64-32

# BetterAuth secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE-ME-betterauth-run-openssl-rand-base64-32

# BetterAuth API key (for Better Auth Infra dashboard)
# Get this from https://dash.better-auth.com after connecting your project
BETTER_AUTH_API_KEY=

# BetterAuth URL (your API URL - used for auth callbacks)
BETTER_AUTH_URL=http://localhost:3000

# API URL for frontend (used by Better Auth client)
VITE_API_URL=http://localhost:3000

# Enforce MFA for admin users
# ENFORCE_ADMIN_MFA=false

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Maximum requests per minute per IP
RATE_LIMIT_MAX=100
# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=60000

# -----------------------------------------------------------------------------
# File Storage [OPTIONAL]
# -----------------------------------------------------------------------------
# STORAGE_TYPE=local
# STORAGE_PATH=./uploads
# STORAGE_BASE_URL=http://localhost:3000/uploads
# S3_BUCKET=
# S3_REGION=eu-west-2
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_EXPORT_BUCKET=
# S3_EXPORT_PREFIX=exports/

# AWS alternative credentials (used if S3_ACCESS_KEY not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Virus Scanning (ClamAV) [OPTIONAL]
# -----------------------------------------------------------------------------
# Enable ClamAV virus scanning for uploaded documents.
# Requires the 'scanning' Docker Compose profile:
#   docker compose --profile scanning up -d
#
# When CLAMAV_ENABLED=false (default), file uploads proceed without scanning.
# When CLAMAV_ENABLED=true and ClamAV is unreachable, uploads proceed in
# degraded mode with a warning logged (fail-open).
# CLAMAV_ENABLED=false
# CLAMAV_HOST=localhost
# CLAMAV_PORT=3310
# CLAMAV_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Email (SMTP) [OPTIONAL]
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@staffora.co.uk

# -----------------------------------------------------------------------------
# Push Notifications — Web Push (VAPID) [OPTIONAL]
# -----------------------------------------------------------------------------
# Generate VAPID keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@staffora.co.uk

# -----------------------------------------------------------------------------
# Push Notifications — Firebase (FCM) [OPTIONAL]
# -----------------------------------------------------------------------------
# FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# Uptime Monitoring (Uptime Kuma) [OPTIONAL]
# -----------------------------------------------------------------------------
# Self-hosted uptime monitoring with status page, alerting, and SSL checks.
# Enable with: docker compose --profile uptime up -d
# Dashboard: http://localhost:3002
# See Docs/operations/uptime-monitoring.md for full setup guide.
# UPTIME_KUMA_PORT=3002

# -----------------------------------------------------------------------------
# Observability — Logging (Loki + Promtail) [OPTIONAL]
# Used by docker-compose.logging.yml
# -----------------------------------------------------------------------------
# Loki HTTP API port (host-side)
# LOKI_PORT=3101

# Log retention period (how long Loki keeps logs). Default: 720h (30 days)
# LOKI_RETENTION_PERIOD=720h

# Grafana port and credentials (shared with monitoring stack)
# GRAFANA_PORT=3100
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=staffora
# GRAFANA_ROOT_URL=http://localhost:3100

# Prometheus port (used by monitoring stack)
# PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Observability — Sentry [OPTIONAL]
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry / Distributed Tracing [OPTIONAL]
# -----------------------------------------------------------------------------
# Enable distributed tracing via OpenTelemetry. Traces are sent to Grafana
# Tempo (included in the monitoring Docker Compose profile) via OTLP HTTP.
#
# Quick start:
#   1. Set OTEL_ENABLED=true
#   2. Run: docker compose --profile monitoring up -d
#   3. Open Grafana (http://localhost:3100) -> Explore -> Tempo
#
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_VERSION=0.1.0
#
# Sampling rate (0.0 to 1.0). Defaults: production=0.1 (10%), staging/dev=1.0 (100%)
# OTEL_SAMPLE_RATE=1.0
# OTEL_TRACES_SAMPLER_ARG=1.0
#
# Enable console span output for local debugging (default: false in prod, true in dev)
# OTEL_CONSOLE_EXPORTER=false
#
# Tempo host ports (used by monitoring profile)
# TEMPO_OTLP_GRPC_PORT=4317
# TEMPO_OTLP_HTTP_PORT=4318
# TEMPO_HTTP_PORT=3200

# -----------------------------------------------------------------------------
# Background Workers [OPTIONAL]
# -----------------------------------------------------------------------------
# WORKER_TYPE=all
# WORKER_HEALTH_PORT=3001
# OUTBOX_BATCH_SIZE=100
# OUTBOX_POLL_INTERVAL=5000
# ENABLE_OUTBOX_POLLING=true

# Export worker
# EXPORT_BASE_URL=http://localhost:3000
# EXPORT_STORAGE_PATH=./exports

# PDF worker
# PDF_BASE_URL=http://localhost:3000
# PDF_STORAGE_PATH=./pdfs

# Worker concurrency and scheduling
# WORKER_CONCURRENCY=5
# WORKER_MAX_RETRIES=3
# WORKER_RETRY_DELAY=5000

# -----------------------------------------------------------------------------
# Database Backups [OPTIONAL]
# -----------------------------------------------------------------------------
# Local backup retention (days). Default: 7
# BACKUP_RETENTION_DAYS=7

# Cron expression for backup schedule. Default: daily at 02:00 UTC
# BACKUP_SCHEDULE=0 2 * * *

# Run a backup immediately when the container starts. Default: false
# BACKUP_ON_START=false

# S3 offsite backup (set S3_BACKUP_BUCKET to enable)
# S3_BACKUP_BUCKET=staffora-backups
# S3_BACKUP_PREFIX=backups/staffora/
# S3_BACKUP_STORAGE_CLASS=STANDARD_IA

# AWS credentials for S3 backup (required if S3_BACKUP_BUCKET is set)
# AWS_DEFAULT_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# S3 retention policy (days)
# S3_DAILY_RETENTION=30
# S3_WEEKLY_RETENTION=90
# S3_MONTHLY_RETENTION=365

# Backup verification: false=off, true/always=every backup, weekly=once per week
# VERIFY_BACKUP=weekly
# Day of week to run weekly verification (1=Monday ... 7=Sunday)
# VERIFY_BACKUP_DAY=7

# -----------------------------------------------------------------------------
# WAL Archiving / Point-in-Time Recovery [OPTIONAL]
# -----------------------------------------------------------------------------
# WAL archiving is enabled by default in postgresql.conf (archive_mode=on).
# Completed WAL segments are copied to the postgres_wal_archive Docker volume.
# Combined with daily pg_dump base backups, this enables point-in-time recovery
# (PITR) to any moment between backups.
#
# Retention for archived WAL files in days. Default: 7
# WAL_ARCHIVE_RETENTION_DAYS=7
#
# See Docs/operations/point-in-time-recovery.md for the full recovery procedure.

# -----------------------------------------------------------------------------
# Database Migrations [OPTIONAL]
# -----------------------------------------------------------------------------
# MIGRATIONS_DIR=./migrations

# -----------------------------------------------------------------------------
# Bootstrap (first-time setup) [OPTIONAL]
# -----------------------------------------------------------------------------
# ROOT_TENANT_NAME=Staffora
# ROOT_TENANT_SLUG=staffora
# ROOT_USER_EMAIL=admin@staffora.co.uk
# ROOT_USER_PASSWORD=
# ROOT_USER_NAME=Admin

# -----------------------------------------------------------------------------
# TLS Certificates (Let's Encrypt / Certbot) [OPTIONAL]
# -----------------------------------------------------------------------------
# Used by scripts/init-letsencrypt.sh for first-time certificate provisioning.
# See Docs/operations/ssl-certificates.md for full documentation.
#
# Space-separated list of domains for the TLS certificate
# CERTBOT_DOMAINS=staffora.co.uk api.staffora.co.uk
#
# Email address for Let's Encrypt expiry notifications
# CERTBOT_EMAIL=admin@staffora.co.uk

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable MFA requirement for all users
FEATURE_MFA_REQUIRED=false
# Enable audit logging
FEATURE_AUDIT_ENABLED=true
# Enable API rate limiting
FEATURE_RATE_LIMIT_ENABLED=true
