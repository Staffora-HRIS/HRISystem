# =============================================================================
# Staffora Platform Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=hris
# Development default: hris_dev_password (matches code defaults)
# In production, change this to a secure password
POSTGRES_PASSWORD=hris_dev_password
POSTGRES_DB=hris
POSTGRES_PORT=5432

# Full database URL (constructed from above, used by application)
# Development default matches POSTGRES_PASSWORD above
DATABASE_URL=postgres://hris:hris_dev_password@localhost:5432/hris

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=3000

# -----------------------------------------------------------------------------
# Web Configuration
# -----------------------------------------------------------------------------
WEB_PORT=5173

# -----------------------------------------------------------------------------
# Authentication (BetterAuth)
# -----------------------------------------------------------------------------
# Session secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-use-openssl-rand-base64-32

# CSRF protection secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
CSRF_SECRET=change-me-use-openssl-rand-base64-32

# BetterAuth secret - must be at least 32 characters
# Generate with: openssl rand -base64 32
# This is the primary secret used by Better Auth for session encryption
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32

# BetterAuth API key (for Better Auth Infra dashboard)
# Get this from https://dash.better-auth.com after connecting your project
BETTER_AUTH_API_KEY=

# BetterAuth URL (your API URL - used for auth callbacks)
BETTER_AUTH_URL=http://localhost:3000

# API URL for frontend (used by Better Auth client)
VITE_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Maximum requests per minute per IP
RATE_LIMIT_MAX=100

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=60000

# -----------------------------------------------------------------------------
# File Storage (future use)
# -----------------------------------------------------------------------------
# STORAGE_TYPE=local
# STORAGE_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# Email (future use)
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable MFA requirement for all users
FEATURE_MFA_REQUIRED=false

# Enable audit logging
FEATURE_AUDIT_ENABLED=true

# Enable API rate limiting
FEATURE_RATE_LIMIT_ENABLED=true
